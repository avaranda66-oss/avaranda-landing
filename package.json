{
  "name": "a-varanda-landing",
  "version": "0.1.0",
  "private": true,
  "description": "Landing page A Varanda criada a partir do DESIGN.md e dos mockups locais.",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
